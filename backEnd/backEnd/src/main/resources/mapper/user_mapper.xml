<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wh.backend.dao.UserDAO">
    <select id="selectOneUser" parameterType="String" resultType="user">
        SELECT * FROM user WHERE login_id = #{login_id}
    </select>


    <insert id="insertUser" parameterType="user">
        INSERT INTO user (login_id, password, nickname, created_at)
        VALUES(#{login_id}, #{password}, #{nickname}, #{created_at})
    </insert>

    <delete id="delete" parameterType="int">
        DELETE FROM user WHERE id=#{id}
    </delete>
</mapper>