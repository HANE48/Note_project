<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wh.backend.dao.UserDAO">
    <select id="selectOneUser" parameterType="String" resultType="user">
        SELECT * FROM users WHERE login_id = #{login_id}
    </select>

    <insert id="insertUser" parameterType="user">
        INSERT INTO users (login_id, password, nickname, created_at)
        VALUES(#{loginId}, #{password}, #{nickname}, #{created_at})
    </insert>

    <delete id="delete" parameterType="int">
        DELETE FROM users WHERE id=#{id}
    </delete>

    <select id="selectOneUserId" parameterType="int" resultType="user">
        SELECT * FROM users WHERE id=#{id}
    </select>

</mapper>